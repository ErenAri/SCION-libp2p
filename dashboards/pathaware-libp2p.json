        {
          "expr": "rate(pathaware_libp2p_blocks_transferred_total{direction=\"sent\"}[1m])",
          "legendFormat": "sent/s",
          "refId": "A"
        },
        {
          "expr": "rate(pathaware_libp2p_blocks_transferred_total{direction=\"received\"}[1m])",
          "legendFormat": "received/s",
          "refId": "B"
        }
      ]
    },
    {
      "title": "Probe Failures",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 14 },
